{
  "name": "@boostos/desktop-v2",
  "version": "0.1.8",
  "description": "Project-scoped IDE/browser/agent surface switcher",
  "main": "./out/main/index.js",
  "author": "BoostOS",
  "homepage": "https://github.com/Lasdw6/Boost",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "build:win": "bun run build"
  },
  "dependencies": {
    "@boostos/boost-auth": "workspace:*",
    "@aws-sdk/client-s3": "^3.863.0",
    "@ai-sdk/openai": "^3.0.0",
    "@electron-toolkit/preload": "^3.0.2",
    "ai": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.7.3",
    "ink": "^6.6.0",
    "koffi": "^2.15.1",
    "node-window-manager": "^2.2.4",
    "ps-list": "^8.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.4",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.8",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.23",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
