# Desktop app env

# Companion API URL (WorkOS auth + server-side LLM)
# Local dev:
BOOST_API_URL=http://localhost:8787
# Production example:
# BOOST_API_URL=https://your-api.onrender.com
# Convex example:
# BOOST_API_URL=https://your-deployment.convex.site

# Backend mode
# - render: expects /stream endpoint
# - convex: uses /updates/poll endpoint
BOOST_BACKEND_MODE=render

# Optional auto-update feed URL (generic provider)
# Example:
# BOOST_UPDATE_FEED_URL=https://downloads.boostos.com/desktop
# If unset, packaged app uses electron-builder publish config.
BOOST_UPDATE_FEED_URL=

# Cloudflare R2 feed upload (used by: bun run feed:upload:r2)
# R2 S3 API endpoint uses account ID: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2 bucket should be publicly readable (or fronted by a public custom domain).
# Example public feed URL with prefix "downloads":
#   R2_PUBLIC_BASE_URL=https://downloads.boostos.ai
#   R2_PREFIX=downloads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_PREFIX=downloads

# Build-time only (do not ship in app env):
# GitHub personal access token used by electron-builder publish.
# Scope needed: repo (classic) or Contents: Read/Write (fine-grained).
# GH_TOKEN=

# Optional local publish token file:
# apps/desktop/.env.publish
# Example content:
# GH_TOKEN=github_pat_xxx

# Legacy local fallback for direct OpenAI usage (optional)
# Prefer server-side keys via apps/api.
OPENAI_API_KEY=


# Dev-only renderer URL (usually set automatically by electron-vite)
# ELECTRON_RENDERER_URL=http://localhost:5173
