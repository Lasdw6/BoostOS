// BoostOS Niri configuration
//
// Niri's scrollable-tiling model maps to BoostOS's multi-agent workflow:
//   - Each workspace = one project context
//   - Columns scroll horizontally within a workspace
//   - One agent's windows per column; scroll/jump to navigate agents
//
// Keybindings use Mod = Super (Windows key).
// Vim-style navigation (H/J/K/L) + arrow keys both work.

// ── Input ─────────────────────────────────────────────────────────────────────

input {
    keyboard {
        xkb {
            // Inherits system keymap; override here if needed:
            // layout "us"
            // options "ctrl:nocaps"
        }
    }

    mouse {
        accel-speed 0.0
    }

    touchpad {
        tap
        natural-scroll
        accel-speed 0.2
    }

    // Moving the cursor to a window focuses it — essential for
    // quickly switching between many agent terminals.
    focus-follows-mouse max-scroll-amount="0%"
}

// ── Layout ────────────────────────────────────────────────────────────────────

layout {
    gaps 6

    // Do not auto-center the focused column — keep it where it is so the
    // scrollable view stays stable while navigating.
    center-focused-column "never"

    // Cycle through these widths with Mod+R.
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    struts {
        left 0
        right 0
        top 0
        bottom 0
    }
}

// ── Appearance ────────────────────────────────────────────────────────────────

// Request server-side decorations from apps — cleaner look, less per-app variance.
prefer-no-csd

cursor {
    xcursor-theme "Adwaita"
    xcursor-size 24
}

// ── Environment ───────────────────────────────────────────────────────────────
// Inject BoostOS service URLs into every app spawned inside Niri.
// This ensures tools launched from a launcher (not a profile-sourced terminal)
// still reach the RAG daemon and API proxy.

environment {
    // Apps spawned inside niri run on Wayland; fall back to X11 via XWayland if needed.
    GDK_BACKEND "wayland,x11"
    QT_QPA_PLATFORM "wayland;xcb"
    // BoostOS service endpoints
    BOOSTOS_RAG_URL "http://127.0.0.1:7700"
    ANTHROPIC_BASE_URL "http://127.0.0.1:7701"
    OPENAI_BASE_URL "http://127.0.0.1:7701"
}

// ── Startup ───────────────────────────────────────────────────────────────────

spawn-at-startup "xfce4-terminal"

// ── Keybindings ──────────────────────────────────────────────────────────────

binds {
    // ── Applications ──────────────────────────────────────────────────────────
    Mod+Return { spawn "xfce4-terminal"; }
    Mod+T      { spawn "xfce4-terminal"; }

    // ── Window management ──────────────────────────────────────────────────────
    Mod+Q         { close-window; }
    Mod+F         { maximize-column; }
    Mod+C         { center-column; }
    Mod+R         { switch-preset-column-width; }    // cycle through preset widths
    Mod+Shift+F   { fullscreen-window; }

    // ── Focus movement ─────────────────────────────────────────────────────────
    Mod+H     { focus-column-left; }
    Mod+L     { focus-column-right; }
    Mod+J     { focus-window-or-workspace-down; }
    Mod+K     { focus-window-or-workspace-up; }
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Down  { focus-window-or-workspace-down; }
    Mod+Up    { focus-window-or-workspace-up; }

    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }

    // ── Move windows ───────────────────────────────────────────────────────────
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+L     { move-column-right; }
    Mod+Shift+J     { move-window-down-or-to-workspace-down; }
    Mod+Shift+K     { move-window-up-or-to-workspace-up; }
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+Down  { move-window-down-or-to-workspace-down; }
    Mod+Shift+Up    { move-window-up-or-to-workspace-up; }

    Mod+Shift+Home { move-column-to-first; }
    Mod+Shift+End  { move-column-to-last; }

    // ── Workspaces ─────────────────────────────────────────────────────────────
    // Workspaces are stacked vertically; each can hold an independent
    // set of scrollable columns. Use one workspace per project/agent context.

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    // ── Column / window sizing ─────────────────────────────────────────────────
    Mod+Minus       { set-column-width "-10%"; }
    Mod+Equal       { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // ── Screenshot ────────────────────────────────────────────────────────────
    Print       { screenshot; }
    Ctrl+Print  { screenshot-screen; }
    Alt+Print   { screenshot-window; }

    // ── Session ───────────────────────────────────────────────────────────────
    // Mod+Shift+E asks for confirmation before quitting.
    Mod+Shift+E { quit; }
}

// ── Window rules ──────────────────────────────────────────────────────────────

window-rule {
    geometry-corner-radius 4
    clip-to-geometry true
}
